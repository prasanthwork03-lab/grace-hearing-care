# Firebase Credentials
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Staff-facing username and the email of the matching Firebase Authentication user.
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_EMAIL=prasanthwork03@gmail.com
# Never place the admin password in a VITE_ variable; VITE_ values are public in the browser bundle.

# Business Contact details
VITE_WHATSAPP_NUMBER=919840029521
VITE_PRIMARY_PHONE=9840029521
